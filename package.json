{
  "name": "my-project",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -p none 'serwist build --watch --config serwist.config.js' 'next dev'",
    "build": "next build && serwist build --config serwist.config.js",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "icons": "npx pwa-asset-generator public/icon.svg public/ --icon-only --favicon --type png --background \"#f9f7f4\" --opaque true --padding \"0%\" --manifest app/manifest.json && sed -i '' 's|\"src\": \"public/|\"src\": \"/|g' app/manifest.json"
  },
  "dependencies": {
    "@serwist/next": "^9.0.10",
    "@vercel/analytics": "1.6.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.564.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "serwist": "^9.0.10",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@serwist/cli": "^9.0.10",
    "@tailwindcss/postcss": "^4.2.0",
    "@types/node": "^22",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "concurrently": "^9.1.2",
    "esbuild": "^0.25.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "postcss": "^8.5",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.0",
    "tw-animate-css": "1.3.3",
    "typescript": "5.7.3"
  }
}
